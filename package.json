{
  "name": "@dev_config/redis",
  "version": "1.0.8",
  "description": "Production-grade Redis infrastructure for distributed systems",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./cache": {
      "types": "./dist/cache.d.ts",
      "import": "./dist/cache.js"
    },
    "./pubsub": {
      "types": "./dist/pubsub.d.ts",
      "import": "./dist/pubsub.js"
    },
    "./lock": {
      "types": "./dist/lock.d.ts",
      "import": "./dist/lock.js"
    },
    "./health": {
      "types": "./dist/health.d.ts",
      "import": "./dist/health.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write 'src/**/*.ts'",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "redis",
    "cluster",
    "sentinel",
    "distributed",
    "cache",
    "pubsub",
    "locking"
  ],
  "author": "Your Organization",
  "license": "MIT",
  "dependencies": {
    "@dev_config/logger": "^1.0.2",
    "ioredis": "^5.11.1",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "ioredis": "^5.11.1",
    "typescript": "^5.0.0 || ^6.0.0 || ^7.0.2",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^26.1.1"
  }
}
